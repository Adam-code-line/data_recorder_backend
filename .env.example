# ===== Server =====
APP_NAME=data-recorder-backend
# IPv6-first binding. Use 0.0.0.0 for IPv4-only environments.
HOST=::
# Set true to force pure IPv6 socket behavior when HOST=::
IPV6_ONLY=true
PORT=8080
LOG_LEVEL=info

# ===== Auth =====
# REQUIRED when REQUIRE_AUTH=true
# Self-use default: keep one token and match Flutter upload_config.dart
AUTH_TOKENS=slam-self-use-token
REQUIRE_AUTH=true

# Optional fallback header for legacy clients
LEGACY_TOKEN_HEADER_NAME=x-upload-token

# ===== Upload Storage =====
UPLOAD_ROOT_DIR=/home/wubin/EmbodMocap_dev/datasets
IDEMPOTENCY_FILE_PATH=/home/wubin/EmbodMocap_dev/datasets/idempotency-store.json

# Uploaded zip files are saved to:
# ${UPLOAD_ROOT_DIR}/${DATASET_CAPTURE_NAME}/${DATASET_SCENE_NAME}/${DATASET_SEQ_NAME}/
DATASET_CAPTURE_NAME=my_capture
DATASET_SCENE_NAME=livingroom1
DATASET_SEQ_NAME=seq0

# Max upload ZIP size (MB)
MAX_FILE_SIZE_MB=1024

# If free disk is below this threshold, upload is rejected (MB)
DISK_FREE_THRESHOLD_MB=1024

# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES=application/zip,application/x-zip-compressed,application/octet-stream,multipart/x-zip

# ===== Cleanup =====
# Retention for uploaded zip files (days)
UPLOAD_RETENTION_DAYS=14

# Cleanup interval (minutes)
CLEANUP_INTERVAL_MINUTES=60

# ===== Metrics =====
# Sample size used for P95 latency calculation
METRICS_WINDOW_SIZE=500
